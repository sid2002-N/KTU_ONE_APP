# KTU One — Environment Variables Template
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DIRECT_URL=postgresql://user:password@host/dbname?sslmode=require

# Scraper backend (existing Express API)
SCRAPER_API_URL=https://your-scraper.on.railway.app
SCRAPER_API_KEY=your-scraper-api-key

# JWT signing (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your-64-byte-hex-secret
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=2592000

# Cached student data TTL (seconds)
CACHE_TTL_SECONDS=86400

# Cron protection (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
CRON_SECRET=your-cron-secret

# Admin API (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ADMIN_API_KEY=your-admin-key

# Cloudflare R2 (private bucket)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=your-bucket

# Razorpay (test mode — switch to rzp_live_ for production)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Upstash Redis (for rate limiting — required in production)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Admin CORS (set to your admin UI origin in production)
ADMIN_ALLOWED_ORIGIN=https://admin.ktuone.in

# ── Capacitor / Android mobile build ─────────────────────────────────────────
# Absolute backend origin the packaged APK calls. Leave NEXT_PUBLIC_API_BASE_URL
# EMPTY for the web build (relative, same-origin). The Capacitor build script
# injects CAP_API_BASE_URL as NEXT_PUBLIC_API_BASE_URL at build time.
NEXT_PUBLIC_API_BASE_URL=
CAP_API_BASE_URL=https://ktu.one

# Set to "true" on the deployment that serves the mobile app so auth cookies are
# issued as SameSite=None; Secure (required for cross-origin WebView requests).
# Keep "false" for web-only deployments (stricter SameSite=Lax / CSRF posture).
CROSS_SITE_COOKIES=false
